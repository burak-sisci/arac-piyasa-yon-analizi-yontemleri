# Dönüşüm çıktıları (docx/pptx/pdf) — git'e girmez
exports/

# Çekilen veri — git'e girmez (prompt/kod versiyonlanır, veri versiyonlanmaz;
# karar K5: yalnızca kamuya açık kaynaklar, şirket içi veri repoya girmez)
# Veri, kaynak adına göre alt klasörlere ayrılmıştır (data/raw/usdtry/,
# data/raw/tufe/ vb.) — yalnızca klasör yapısı (.gitkeep) versiyonlanır.
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep
# Alt klasörlerin kendisi görünür olsun (icine girilebilsin):
!data/raw/*/
!data/processed/*/
# ...ama icindeki HER SEY yine varsayilan olarak gizli kalsin:
data/raw/*/*
data/processed/*/*
# ...yalnizca .gitkeep'ler ve raporlar/ altindaki .md'ler istisna:
!data/raw/*/.gitkeep
!data/processed/*/.gitkeep
!data/processed/raporlar/*.md

# API anahtarları / gizli bilgiler — asla git'e girmez
.env

# Office/PowerPoint kilit dosyaları
~$*.docx
~$*.pptx
~$*.xlsx

# Python (pandoc/python-docx/python-pptx yardımcı scriptleri için)
__pycache__/
*.pyc
.venv/
venv/

# OS
.DS_Store
Thumbs.db

# Editör
.vscode/
.idea/
